{
  "name": "@refineddigital/cms-form-builder",
  "version": "1.13.5",
  "description": "Form Builder for Refined CMS",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "npm run build:frontend && vite build --watch",
    "development": "npm run build",
    "watch": "npm run dev",
    "build": "vite build && npm run build:frontend",
    "build:frontend": "vite build --config vite.frontend.config.js",
    "prod": "npm run build",
    "production": "npm run build",
    "publish-and-tag": "git push --tags && git push origin master",
    "version:patch": "npm version patch && npm run publish-and-tag",
    "version:minor": "npm version minor && npm run publish-and-tag",
    "version:major": "npm version major && npm run publish-and-tag"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/refineddigital/cms-product-manager.git"
  },
  "author": "Matthias Law",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/refineddigital/cms-product-manager/issues"
  },
  "homepage": "https://github.com/refineddigital/cms-product-manager#readme",
  "dependencies": {
    "vue": "^3.5.38",
    "vuedraggable": "^4.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.0",
    "sass": "^1.101.0",
    "terser": "^5.48.0",
    "vite": "^7.0.0"
  }
}
